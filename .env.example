# ━━━ Déploiement Vercel + Supabase (référence rapide) ━━━
# Obligatoires : DATABASE_URL, DIRECT_URL, JWT_SECRET (32+)
# Si STORAGE_DRIVER=supabase : SUPABASE_URL, SUPABASE_SERVICE_ROLE_KEY
# Recommandé prod : NEXT_PUBLIC_APP_URL = https://votre-app.vercel.app

# PostgreSQL
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/dossierloc?schema=public"
# Même valeur en local. Sur Supabase : URL « Transaction pooler » (:6543) pour l’app, et ci-dessous l’URL « Direct » (:5432, hôte db.xxx.supabase.co).
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/dossierloc?schema=public"

# JWT (32+ caractères aléatoires, différent dev/prod)
JWT_SECRET="changez-moi-avec-une-cle-longue-et-vraiment-aleatoire"
JWT_ISSUER="dossierloc"
JWT_AUDIENCE="dossierloc-users"

# Uploads
MAX_FILE_BYTES=10485760
UPLOAD_DIR="./uploads"

# Stockage : local | s3 | supabase
# Sur Vercel : sans backend d’objets, évitez local (fichiers éphémères sous /tmp). Préférez supabase ou s3.
STORAGE_DRIVER=local

# Supabase Storage (si STORAGE_DRIVER=supabase)
# Créer un bucket privé nommé « documents » (voir rapport / doc projet). Jamais exposer SUPABASE_SERVICE_ROLE_KEY au navigateur.
# SUPABASE_URL="https://xxxx.supabase.co"
# SUPABASE_SERVICE_ROLE_KEY=""
# SUPABASE_STORAGE_BUCKET="documents"

# S3 (si STORAGE_DRIVER=s3)
S3_BUCKET=
S3_REGION=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_PUBLIC_BASE_URL=

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
