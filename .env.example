# PostgreSQL
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/dossierloc?schema=public"
# Même valeur en local. Sur Supabase : URL « Transaction pooler » (:6543) pour l’app, et ci-dessous l’URL « Direct » (:5432, hôte db.xxx.supabase.co).
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/dossierloc?schema=public"

# JWT (32+ caractères aléatoires, différent dev/prod)
JWT_SECRET="changez-moi-avec-une-cle-longue-et-vraiment-aleatoire"
JWT_ISSUER="dossierloc"
JWT_AUDIENCE="dossierloc-users"

# Uploads
MAX_FILE_BYTES=10485760
UPLOAD_DIR="./uploads"

# Stockage : local | s3
STORAGE_DRIVER=local

# S3 (si STORAGE_DRIVER=s3)
S3_BUCKET=
S3_REGION=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_PUBLIC_BASE_URL=

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
