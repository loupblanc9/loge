# ━━━ Copie ce fichier en .env.local et remplis les valeurs (ne committe jamais .env.local) ━━━
#
# OBLIGATOIRES (serveur + Prisma)
# --------------------------------
DATABASE_URL="postgresql://USER:PASSWORD@HOST:6543/postgres?pgbouncer=true"
# Pooler Supabase (port 6543) pour l’app en prod / serverless.
#
DIRECT_URL="postgresql://USER:PASSWORD@db.PROJECT_REF.supabase.co:5432/postgres"
# Connexion DIRECTE pour Prisma (migrations). Sur Supabase : copie l’URI « Direct »
# (hôte db.<ref>.supabase.co, port 5432). Évite d’utiliser le pooler :5432 pour DIRECT_URL si la doc Supabase le déconseille.

JWT_SECRET="minimum-32-caracteres-aleatoires-forts-differents-en-prod"

# STOCKAGE
# --------
# local | s3 | supabase
STORAGE_DRIVER=supabase

# Si STORAGE_DRIVER=supabase (backend uniquement — jamais préfixe NEXT_PUBLIC_)
SUPABASE_URL="https://PROJECT_REF.supabase.co"
SUPABASE_SERVICE_ROLE_KEY=""
SUPABASE_STORAGE_BUCKET="documents"

# OPTIONNEL (défauts dans le code si absent)
MAX_FILE_BYTES=10485760
UPLOAD_DIR="./uploads"
JWT_ISSUER="dossierloc"
JWT_AUDIENCE="dossierloc-users"

# FRONT / URL publique (exposé au navigateur si utilisé côté client)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# OPTIONNEL — uniquement si tu utilises le client Supabase dans le navigateur (non requis par le flux fichiers actuel)
# NEXT_PUBLIC_SUPABASE_URL="https://PROJECT_REF.supabase.co"
# NEXT_PUBLIC_SUPABASE_ANON_KEY=""

# Si STORAGE_DRIVER=s3
# S3_BUCKET=
# S3_REGION=
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# S3_PUBLIC_BASE_URL=

# Seed Prisma (optionnel, prisma/seed.ts uniquement)
# SEED_ADMIN_EMAIL=
# SEED_ADMIN_PASSWORD=
